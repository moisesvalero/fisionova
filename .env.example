# Copy this file to .env.local and fill only the values your app needs.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional Supabase integration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Sanity integration
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# Optional OpenAI integration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# Private demo dashboard. Change this before deploying to Vercel.
DOCTOR_DASHBOARD_PIN=1234
# Optional secret for signed appointment email actions.
APPOINTMENT_ACTION_SECRET=

# Optional Resend integration
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_REPLY_TO_EMAIL=
# Demo mode: route all emails to a verified Resend test inbox.
RESEND_TEST_RECIPIENT=
